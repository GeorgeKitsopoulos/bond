#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
BOND_ROOT="${BOND_ROOT:-$(cd "$SCRIPT_DIR/.." && pwd)}"
export BOND_ROOT
export PYTHONPATH="$BOND_ROOT/src${PYTHONPATH:+:$PYTHONPATH}"
exec python3 "$BOND_ROOT/src/bond/ai_selftest.py" "$@"
